# LLM provider: ollama | azure_openai
LLM_PROVIDER=azure_openai

# Azure OpenAI (existing deployment)
AZURE_OPENAI_ENDPOINT=https://testing-chat-beta.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_MAX_TOKENS=4096

# Retrieval
HYBRID_RETRIEVAL_ENABLED=true
PGVECTOR_ENABLED=true

# Security (optional — leave empty to disable)
API_KEY=
BENCHMARK_RATE_LIMIT_PER_HOUR=10
BENCHMARK_MIN_OVERALL=0.85
BENCHMARK_MIN_BELIEF_QUALITY=0.55
DEFAULT_TENANT_ID=default

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://acme:acme@localhost:5432/acme

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=acmepassword

# Ollama (local dev only — set LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EXTRACTION_MODEL=qwen3.5:latest
OLLAMA_REASONING_MODEL=qwen3.5:latest
OLLAMA_COMPRESSION_MODEL=qwen3.5:latest
OLLAMA_LEARNING_MODEL=qwen3.5:latest

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
